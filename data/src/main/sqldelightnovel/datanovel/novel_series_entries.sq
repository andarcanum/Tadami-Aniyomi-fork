CREATE TABLE novel_series_entries (
    _id INTEGER NOT NULL PRIMARY KEY,
    series_id INTEGER NOT NULL,
    novel_id INTEGER NOT NULL,
    position INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY(series_id) REFERENCES novel_series(_id) ON DELETE CASCADE,
    FOREIGN KEY(novel_id) REFERENCES novels(_id) ON DELETE CASCADE
);

CREATE UNIQUE INDEX novel_series_entries_novel_id ON novel_series_entries(novel_id);
CREATE INDEX novel_series_entries_series_id ON novel_series_entries(series_id);

getEntriesBySeriesId:
SELECT * FROM novel_series_entries WHERE series_id = :seriesId ORDER BY position;

getEntryByNovelId:
SELECT * FROM novel_series_entries WHERE novel_id = :novelId;

getAllNovelIdsInAnySeries:
SELECT novel_id FROM novel_series_entries;

insert:
INSERT INTO novel_series_entries(series_id, novel_id, position)
VALUES (:seriesId, :novelId, :position);

deleteByNovelId:
DELETE FROM novel_series_entries WHERE novel_id = :novelId;

deleteBySeriesId:
DELETE FROM novel_series_entries WHERE series_id = :seriesId;

getAllEntries:
SELECT * FROM novel_series_entries ORDER BY position;

updatePosition:
UPDATE novel_series_entries
SET position = :position
WHERE _id = :id;
