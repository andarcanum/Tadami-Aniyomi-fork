import kotlin.Boolean;

CREATE TABLE manga_series (
    _id INTEGER NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    category_id INTEGER NOT NULL DEFAULT 0,
    sort_order INTEGER NOT NULL DEFAULT 0,
    date_added INTEGER NOT NULL DEFAULT 0,
    cover_last_modified INTEGER NOT NULL DEFAULT 0,
    pinned INTEGER AS Boolean NOT NULL DEFAULT 0
);

CREATE INDEX manga_series_category_index ON manga_series(category_id);

getAllSeries:
SELECT * FROM manga_series;

getSeriesById:
SELECT * FROM manga_series WHERE _id = :id;

getSeriesByCategory:
SELECT * FROM manga_series WHERE category_id = :categoryId ORDER BY sort_order;

insert:
INSERT INTO manga_series(title, description, category_id, sort_order, date_added, cover_last_modified, pinned)
VALUES (:title, :description, :categoryId, :sortOrder, :dateAdded, :coverLastModified, :pinned);

update:
UPDATE manga_series
SET title = coalesce(:title, title),
    description = coalesce(:description, description),
    category_id = coalesce(:categoryId, category_id),
    sort_order = coalesce(:sortOrder, sort_order),
    date_added = coalesce(:dateAdded, date_added),
    cover_last_modified = coalesce(:coverLastModified, cover_last_modified),
    pinned = coalesce(:pinned, pinned)
WHERE _id = :id;

delete:
DELETE FROM manga_series WHERE _id = :id;

selectLastInsertedRowId:
SELECT last_insert_rowid();
